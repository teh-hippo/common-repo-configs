{
  // Shared Renovate base preset for all teh-hippo repositories.
  // See README.md for the policy summary and per-repo slot allocation.
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  extends: [
    "config:best-practices",
    ":enableVulnerabilityAlertsWithLabel(security)",
    ":semanticCommits",
    ":rebaseStalePrs",
  ],

  timezone: "Australia/Sydney",
  labels: ["dependencies"],

  // Auto-merge everything that passes CI. Failure is the only gate.
  automerge: true,
  platformAutomerge: true,

  // Off by design: cosmetic for a fully-autonomous estate, and blind to transitive-lockfile
  // CVEs anyway (its OSV summary is direct-deps-only). The signal is GitHub's Dependabot alert.
  dependencyDashboard: false,

  // Broaden vulnerability detection beyond GHSA (covers PyPI / Go / Cargo earlier).
  osvVulnerabilityAlerts: true,

  // Let researchers detect bad releases (supply-chain attacks, broken publishes) before we adopt them.
  // best-practices already enforces this for npm; we extend the principle to every ecosystem.
  // Vulnerability PRs override this to 0 below.
  minimumReleaseAge: "3 days",

  // Harmless on non-forks; required for forks (foxess-ha, icloud_photos_downloader).
  forkProcessing: "enabled",

  // Default: dep updates are housekeeping and must not cut a release.
  // Overridden below for runtime deps so end-users actually receive the fix.
  semanticCommitScope: "deps",
  semanticCommitType: "chore",

  // Transitive CVEs live only in the lock file and Renovate cannot target them directly;
  // a DAILY relock is the vanilla, autonomous path that clears them (overrides
  // best-practices' weekly lock-file maintenance). Applies to uv.lock, Cargo.lock, etc.
  lockFileMaintenance: {
    enabled: true,
    schedule: ["before 6am"],
    automerge: true,
    platformAutomerge: true,
  },

  packageRules: [
    {
      description: "Runtime deps trigger a patch release so downstream users receive the update.",
      matchDepTypes: [
        "dependencies",
        "require",
        "optionalDependencies",
        "peerDependencies",
      ],
      semanticCommitType: "fix",
    },
    {
      description: "Cargo: keep bumps lock-file-only so a stray range never forces manifest churn.",
      matchManagers: ["cargo"],
      rangeStrategy: "update-lockfile",
    },
    {
      description: "Pin and digest updates carry no new source, so the release-age soak only stalls them (a rebuilt tag re-pins a fresh digest and resets the clock forever). Merge as soon as CI is green.",
      matchUpdateTypes: ["pin", "pinDigest", "digest"],
      minimumReleaseAge: "0",
    },
  ],

  // Security lands immediately, ungrouped, and auto-merges on its own green CI, so a
  // routine or lock-file PR failure can never block a security fix.
  vulnerabilityAlerts: {
    minimumReleaseAge: "0",
    automerge: true,
    platformAutomerge: true,
  },
}
